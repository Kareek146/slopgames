-- Nyx | +1 Speed Ninja Escape
print("✅ Nyx +1 Speed Ninja Escape loaded")

local repo = "https://raw.githubusercontent.com/mstudio45/LinoriaLib/main/"
local Library = loadstring(game:HttpGet(repo .. "Library.lua"))()

local Window = Library:CreateWindow({
    Title = "Nyx - +1 Speed Ninja Escape",
    Center = true,
    AutoShow = true,
})

local Tab = Window:AddTab("Main")
local LeftGroupBox = Tab:AddLeftGroupbox("Twoje Skrypty")

LeftGroupBox:AddButton({
    Text = "Add Speed x1000",
    Func = function()
        for i = 1, 1000 do
            pcall(function()
                local Event = game:GetService("ReplicatedStorage").Events.AddSpeed
                Event:FireServer()
            end)
        end
    end
})

LeftGroupBox:AddButton({
    Text = "Request Rebirth",
    Func = function()
        pcall(function()
            local Event = game:GetService("ReplicatedStorage").Events.RequestRebirth
            Event:InvokeServer()
        end)
    end
})

-- NOWY TELEPORT
LeftGroupBox:AddButton({
    Text = "Wins Farm (Teleport)",
    Func = function()
        local player = game.Players.LocalPlayer
        if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            player.Character.HumanoidRootPart.CFrame = CFrame.new(407, 218, 4387)
        end
    end
})

print("Nyx menu loaded with Wins Farm teleport")
