-- Nyx | +1 Speed Ninja Escape
print("Nyx +1 Speed Ninja Escape loaded")

-- Prostsza biblioteka UI (bardziej stabilna)
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/violin-suzutsuki/LinoriaLib/main/Library.lua"))()
local Window = Library:CreateWindow({
    Title = "Nyx - +1 Speed Ninja Escape",
    Center = true,
    AutoShow = true,
})

local Tab = Window:AddTab("Main")

Tab:AddSection("Twoje Skrypty")

-- =================== TWOJE PRZYCISKI ===================

Tab:AddButton({
    Title = "Add Speed x1000",
    Description = "Dodaje speed 1000 razy",
    Callback = function()
        for i = 1, 1000 do
            local Event = game:GetService("ReplicatedStorage").Events.AddSpeed
            Event:FireServer()
        end
        Library:Notify("Speed x1000 wykonane!", 3)
    end
})

Tab:AddButton({
    Title = "Request Rebirth",
    Description = "Robi rebirth",
    Callback = function()
        local Event = game:GetService("ReplicatedStorage").Events.RequestRebirth
        Event:InvokeServer()
        Library:Notify("Rebirth wysłany!", 3)
    end
})

